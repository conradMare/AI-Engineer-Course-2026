   "source": [
    "Let x represent the number of orders received during a certain day. Create a program that prints \"A busy day\" if x is greater than 100, and \"A calm day\" otherwise."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "4ff68be5-ac9e-4fa8-9619-fa5caa49335b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "A calm day\n"
     ]
    }
   ],
   "source": [
    "x = 100\n",
    "\n",
    "if (x > 100):\n",
    "    print (\"A busy day\")\n",
    "else:\n",
    "    print (\"A calm day\")"
   ]
  },
