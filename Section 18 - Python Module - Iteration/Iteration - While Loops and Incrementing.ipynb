   "source": [
    "x = 0\n",
    "\n",
    "# DON NOT DO THIS == infinite loop\n",
    "# while x <= 20:\n",
    "#     print (x)\n",
    "\n",
    "# Correct aproach\n",
    "while x <= 20:\n",
    "    print (x, end = \" \")\n",
    "    x = x + 2"
   ]
