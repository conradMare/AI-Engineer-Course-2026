     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Name: Peter\n",
      "Age: 24\n"
     ]
    }
   ],
   "source": [
    "name_age = 'Peter,24'\n",
    "\n",
    "name, age = name_age.split(',')\n",
    "\n",
    "print(\"Name:\", name)\n",
