   "source": [
    "Use a list comprehension to return a list with all even numbers between 1 and 10 inclusive, multiplied by 10.\n",
    "\n",
    "Please remember to use the print() function to print out the desired output."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "28c58361-4f48-46f1-ab9f-e8c895516d8b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[20, 40, 60, 80, 100]\n"
     ]
    }
   ],
   "source": [
    "print([x * 10 for x in range(1, 11) if x % 2 == 0])"
   ]
